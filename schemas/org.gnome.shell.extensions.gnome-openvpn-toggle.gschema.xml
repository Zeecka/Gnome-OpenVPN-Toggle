<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.gnome-openvpn-toggle"
          path="/org/gnome/shell/extensions/gnome-openvpn-toggle/">

    <key name="profiles-dir" type="s">
      <default>'~/.config/openvpn'</default>
